{
  "name": "ai-clone-kit",
  "version": "1.0.0",
  "description": "Build AI clones and voice agents fast. LLM orchestration + RAG + voice synthesis.",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "test": "jest",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:watch": "jest --watch",
    "migration:run": "ts-node -r tsconfig-paths/register src/database/run-migration.ts",
    "example:assistant": "ts-node -r tsconfig-paths/register examples/01-personal-assistant.ts",
    "example:support": "ts-node -r tsconfig-paths/register examples/02-support-bot.ts",
    "example:domain": "ts-node -r tsconfig-paths/register examples/03-domain-expert.ts",
    "example:voice": "ts-node -r tsconfig-paths/register examples/04-voice-agent.ts",
    "example:multi": "ts-node -r tsconfig-paths/register examples/05-multi-agent.ts",
    "example:tools": "ts-node -r tsconfig-paths/register examples/06-tools-integration.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "bullmq": "^5.34.5",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.2",
    "joi": "^17.13.3",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.77.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
